# Required for Claude-powered narration and rules answers
ANTHROPIC_API_KEY=sk-ant-...

# Chat model for the DM pipeline (default: claude-opus-4-6)
CLAUDE_CHAT_MODEL=claude-opus-4-6

# Optional: local Ollama chat fallback (not used when Anthropic key is set)
# OLLAMA_CHAT_MODEL=gemma3:12b

# Optional: cross-encoder reranking model for RAG
# RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Optional: Ollama request timeout in seconds (embeddings / ingest)
# OLLAMA_REQUEST_TIMEOUT=600
